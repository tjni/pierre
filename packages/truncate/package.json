{
  "name": "@pierre/truncate",
  "version": "0.0.2",
  "license": "apache-2.0",
  "files": [
    "dist",
    "LICENSE.md",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": {
      "import": "./dist/style.css"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --clean",
    "dev": "echo 'Watching for changes…' && tsdown --watch --log-level error",
    "test": "bun test --pass-with-no-tests",
    "tsc": "tsgo --noEmit --pretty",
    "prepublishOnly": "moon run truncate:prepublish"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
