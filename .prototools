bun = "1.3.14"
gh = "2.93.0"
node = "24.11.0"
proto = "0.57.4"
moon = "2.3.3"

[plugins]
gh = "file://./.proto/plugins/gh.toml"

[settings]
# No auto-clean: it deletes stale versions from the user-global ~/.proto store
# as a side effect of `proto use`, and one unwritable leftover dir (e.g. a
# root-owned tool from a sudo'd install) hard-fails repo bootstrap. Clean
# explicitly with `proto clean` instead.
auto-install = true
telemetry = false
